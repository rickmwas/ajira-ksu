# =========================================================================
# Ajira Digital Club Kisii University - Environment Variables Configuration
# =========================================================================

# --- SUPABASE CONFIGURATION (Obtain from Supabase Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- DOMAIN ROUTING CONFIGURATION (For production cross-app redirects)
NEXT_PUBLIC_WEBSITE_DOMAIN=ajiraksu.org
NEXT_PUBLIC_PORTAL_DOMAIN=portal.ajiraksu.org
NEXT_PUBLIC_ADMIN_DOMAIN=admin.ajiraksu.org

# --- DEVELOPMENT CROSS-APP URLS (For local testing of redirect callbacks)
# The Portal runs on port 3001 and Admin runs on port 3002 during local dev
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
